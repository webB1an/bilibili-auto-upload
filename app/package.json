{
  "name": "wallpaper-studio",
  "version": "1.0.0",
  "description": "Wallpaper Studio — download, Baidu share, pan-control, Bilibili upload",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "com.wallpaperstudio.app",
    "productName": "Wallpaper Studio",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "scripts/**/*",
      "bundled/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts/wallpaper-download",
        "to": "wallpaper-download"
      },
      {
        "from": "bundled/bilibili-cli",
        "to": "bilibili-cli"
      }
    ],
    "win": {
      "target": ["nsis"],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "webB1an",
      "repo": "bilibili-auto-upload"
    }
  }
}
